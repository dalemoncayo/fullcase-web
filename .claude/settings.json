{
  "permissions": {
    "defaultMode": "default",
    "allow": [
      "Bash(ls:*)",
      "Bash(tree:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(mkdir:*)",
      "Bash(touch:*)",
      "Bash(mv:*)",
      "Bash(cp:*)",
      "Bash(npm install:*)",
      "Bash(npm ci:*)",
      "Bash(npm run:*)",
      "Bash(npm exec:*)",
      "Bash(npm test:*)",
      "Bash(npm ls:*)",
      "Bash(npx:*)",
      "Bash(pnpm install:*)",
      "Bash(pnpm run:*)",
      "Bash(yarn install:*)",
      "Bash(yarn run:*)",
      "Bash(next:*)",
      "Bash(tsc:*)",
      "Bash(eslint:*)",
      "Bash(prettier:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git stash:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr view:*)"
    ],
    "deny": [
      "Bash(rm :*)",
      "Bash(rm -:*)",
      "Bash(sudo:*)",
      "Bash(chmod:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(pkill:*)",
      "Bash(kill:*)",
      "Bash(git reset:*)",
      "Bash(git rebase:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git clean:*)",
      "Read(.env:*)",
      "Read(.env.local:*)",
      "Read(.env.*.local:*)",
      "Read(**/*id_rsa*)",
      "Read(**/*id_ed25519*)",
      "Read(**/*api_key*)",
      "Read(**/*secret_key*)",
      "Read(**/*credentials*)",
      "Read(**/service-account*.json)",
      "Write(.env:*)",
      "Write(.env.local:*)",
      "Write(**/secrets/**)"
    ]
  }
}
