BRANCH_NAME=$(git rev-parse --abbrev-ref HEAD)

# List of branches to ignore (e.g., release-1.0.0, evaluation-sprint10)
EXEMPT_BRANCHES="^(main|master|develop|staging|evaluation|evaluation-sprint.*|release-[0-9]+\.[0-9]+\.[0-9]+)$"

# Allowed categories
CATEGORIES="feature|bugfix|hotfix|test|experimental|build|release|merge|improvement|task|subtask|chore|docs|refactor"

# Allowed branch naming pattern
PATTERN="^($CATEGORIES)\/"

# Skip check for exempt branches
# shellcheck disable=SC2039
if [[ "$BRANCH_NAME" =~ $EXEMPT_BRANCHES ]]; then
  echo "✅ Skipping branch name check for: $BRANCH_NAME"
  exit 0
fi

# Enforce branch naming convention
# shellcheck disable=SC2039
if ! [[ "$BRANCH_NAME" =~ $PATTERN ]]; then
  echo "❌ Invalid branch name: '$BRANCH_NAME'"
  echo "✅ Allowed format: <category>/reference_description-in-kebab-case"
  echo "✅ Allowed categories: $CATEGORIES"
  exit 1
fi

echo "✅ Branch name is valid: $BRANCH_NAME"
exit 0
